# ===== APPLICATION =====
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ismap
DB_USER=postgres
DB_PASSWORD=your_password_here

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# ===== STRIPE =====
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# ===== AIRTEL MONEY =====
AIRTEL_API_URL=https://api.airtel.ga
AIRTEL_USERNAME=your_username
AIRTEL_PASSWORD=your_password
AIRTEL_MERCHANT_ID=your_merchant_id
AIRTEL_API_KEY=your_api_key

# ===== MOOV MONEY =====
MOOV_API_URL=https://api.moov.ga
MOOV_USERNAME=your_username
MOOV_PASSWORD=your_password
MOOV_MERCHANT_ID=your_merchant_id
MOOV_API_KEY=your_api_key

# ===== SINGPAY (Unified API for Airtel Money & Moov Money) =====
# Documentation: https://client.singpay.ga/doc/reference/index.html
SINGPAY_API_URL=https://gateway.singpay.ga/v1
SINGPAY_CLIENT_ID=your_client_id_here
SINGPAY_CLIENT_SECRET=your_client_secret_here
SINGPAY_WALLET_ID=your_wallet_id_here
SINGPAY_DISBURSEMENT_ID=your_disbursement_id_here (optional, required for production)
SINGPAY_CALLBACK_URL=http://localhost:3000/api/paiements/singpay-webhook

# ===== EMAIL SERVICE =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@ismap.ga
EMAIL_SERVICE=Gmail

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ===== SECURITY =====
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
