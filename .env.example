# PRODUCTION - Ne pas versionner les vrais secrets
# Tout le contenu de ce fichier doit être configuré dans Heroku Config Vars

# Serveur
PORT=
NODE_ENV=production

# Base de données (De Heroku MySQL add-on)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT (Générer avec: node -e "require('crypto').randomBytes(32).toString('hex')")
JWT_SECRET=
JWT_EXPIRE=7d

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ISMAP² <no-reply@ismap2.com>

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Paiements
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

AIRTEL_API_URL=https://api.airtel.ga
AIRTEL_MERCHANT_ID=ISMAP_001
AIRTEL_API_KEY=
AIRTEL_API_SECRET=

MOOV_API_URL=https://api.moov.ga
MOOV_USERNAME=
MOOV_PASSWORD=
MOOV_MERCHANT_ID=ISMAP_001
MOOV_API_KEY=

# URLs
API_URL=https://votre-app.herokuapp.com
